*.a
*.so
*.dylib
*.dll

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Python
__pycache__/
*.py[cod]
.Python
*.egg-info/
.venv/
venv/

# Logs / cores
*.log
core
vgcore.*

# Local env (secrets, machine-specific)
.env
.env.*
